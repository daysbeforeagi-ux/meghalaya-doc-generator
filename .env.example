# ── Anthropic ──────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Site ───────────────────────────────────────────────────────────────────────
SITE_DOMAIN=orator.yourdomain.com
SITE_ORIGIN=https://orator.yourdomain.com

# ── Backend ────────────────────────────────────────────────────────────────────
SECRET_KEY=change-me-to-a-long-random-string
SESSION_EXPIRY_HOURS=24
MAX_UPLOAD_MB=20
RATE_LIMIT_PER_IP=10

# ── Storage (absolute paths inside the container) ─────────────────────────────
STORAGE_DIR=/app/storage
PROFILES_DIR=/app/profiles
REFERENCE_DIR=/app/reference

# ── Frontend ───────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=https://orator.yourdomain.com/api
