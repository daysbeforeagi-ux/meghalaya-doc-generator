# ── Required ──────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Site ─────────────────────────────────────────────────────────────────────
# Your domain name (no https://, no trailing slash)
SITE_DOMAIN=orator.example.com

# ── Storage ───────────────────────────────────────────────────────────────────
# Dev default: ./orator.db  |  Prod: /var/lib/orator/orator.db
DB_PATH=./orator.db
OUTPUTS_DIR=./outputs

# ── Budget caps per generation (§8.6) ─────────────────────────────────────────
MAX_SEARCHES=20
MAX_PAGES=30
MAX_WALL_CLOCK_SECS=300

# ── Rate limiting (§4) ───────────────────────────────────────────────────────
MAX_GENERATIONS_PER_SESSION=10
# Per-IP limits for generation and session-poll endpoints (slowapi format)
RATE_LIMIT_GENERATE=10 per hour
RATE_LIMIT_SESSION=20 per hour

# ── Frontend (Next.js) ───────────────────────────────────────────────────────
# In production the frontend calls /api via the same-origin Nginx proxy —
# leave NEXT_PUBLIC_API_BASE empty or unset.
# In dev the Next.js rewrite (next.config.ts) proxies /api/* to localhost:8000
# automatically, so this is also unneeded in dev.
# Only set this if you run the frontend on a different host than the API.
# NEXT_PUBLIC_API_BASE=
